---
import { render, type CollectionEntry } from "astro:content";
import AsciiContainer from "../../content/ascii/AsciiContainer.astro";

type Props = {
  entry: CollectionEntry<"diary">;
  linkToPage?: boolean;
};

const { entry, linkToPage = true } = Astro.props;
const { Content } = await render(entry);
---

<div class="diary-entry">
  <article class="entry">
    <header class="entry-header">
      <h3 class="entry-date">
        {
          linkToPage ? (
            <a href={`/${entry.id}/`}>{entry.data.pubDate}</a>
          ) : (
            entry.data.pubDate
          )
        }
      </h3>
    </header>
    <div class="entry-content">
      <Content />
    </div>
    {entry.data.asciiArt && <AsciiContainer name={entry.data.asciiArt} />}
  </article>
</div>

<style>
  .diary-entry {
    border: 1px dotted pink;
    padding: 10px;
    margin-bottom: 20px;
    background-color: rgba(255, 255, 255, 0.3);
    color: black;
  }

  .entry {
    margin-bottom: 1.25rem;
  }

  .entry-header {
    margin-bottom: 0.5rem;
  }

  .entry-date {
    margin: 0;
    color: white;
    text-shadow: 5px 5px 5px pink;
    font-size: 20px;
    text-decoration: underline;
    text-decoration-color: pink;
    text-decoration-thickness: 2px;
    text-decoration-style: dotted;
    text-decoration-offset: 2px;
  }

  .entry-date a {
    color: inherit;
    text-decoration: none;
  }

  .entry-date a:hover {
    text-decoration: underline;
  }
  .entry-content {
    text-align: center;
    color: black;
    text-shadow: 5px 5px 5px rgb(0, 255, 255);
  }

  .entry-content :global(h1) {
    text-align: center;
    color: yellow;
    border-bottom: 1px solid yellow;
  }

  .entry-content :global(h4) {
    margin-top: 0;
  }

  .entry-content :global(p) {
    margin: 0.5rem 0;
  }
</style>
