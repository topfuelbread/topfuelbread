<nav class="retro-nav">
  <div class="nav-terminal">
    <div class="terminal-header">
      <span class="terminal-title">[ NAVIGATION ]</span>
    </div>
    <ul class="nav-list">
      <li class="click-now">
        <a href="/" class="nav-link">▶ Click to Go Back to Reality!</a>
      </li>
      <li><a href="/if/about/" class="nav-link">▶ About</a></li>
      <li>
        <a href="/if/ascii-art-gallery/" class="nav-link">▶ ASCII ART GALLERY</a
        >
      </li>
      <li><a href="/if/shin-ai/" class="nav-link">▶ shin-ai v0.0.1</a></li>
    </ul>
  </div>
</nav>

<style>
  @import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap");

  .retro-nav {
    margin-bottom: 30px;
    font-family: "JetBrains Mono", monospace;
  }

  .nav-terminal {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a0a2e 100%);
    border: 3px solid #00ffff;
    border-radius: 0;
    box-shadow:
      0 0 20px rgba(0, 255, 255, 0.5),
      inset 0 0 20px rgba(0, 255, 255, 0.1);
    overflow: hidden;
  }

  .terminal-header {
    background-color: rgba(0, 255, 255, 0.1);
    border-bottom: 2px solid #00ffff;
    padding: 12px 16px;
    text-align: center;
  }

  .terminal-title {
    color: #00ffff;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    text-shadow: 0 0 10px rgba(0, 255, 255, 0.8);
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 16px 0;
  }

  .nav-list li {
    border-bottom: 1px solid rgba(0, 255, 255, 0.2);
  }

  .nav-list li:last-child {
    border-bottom: none;
  }

  .nav-link {
    display: block;
    padding: 16px 20px;
    text-decoration: none;
    color: #00ffff;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: all 0.3s ease;
    position: relative;

    text-shadow:
      0 0 5px rgba(0, 255, 255, 0.8),
      0 0 10px rgba(255, 0, 255, 0.3);
  }

  /* Special gold, casino-style link */
  .click-now .nav-link {
    color: #ffd700; /* gold */
    font-weight: 700;
    background: linear-gradient(
      90deg,
      rgba(255, 215, 0, 0.08),
      rgba(255, 223, 93, 0.06)
    );
    text-shadow:
      0 0 6px rgba(255, 215, 0, 0.9),
      0 0 12px rgba(255, 184, 28, 0.6);
    overflow: hidden;
  }

  /* subtle shimmer sweep */
  .click-now .nav-link::after {
    content: "";
    position: absolute;
    top: -30%;
    left: -50%;
    width: 60%;
    height: 160%;
    background: linear-gradient(
      120deg,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.45) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: rotate(25deg);
    opacity: 0.6;
    pointer-events: none;
    mix-blend-mode: screen;
    animation: shimmer 2s linear infinite;
  }

  /* sparkling particles (small) */
  .click-now .nav-link .sparkle {
    position: absolute;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: radial-gradient(
      circle at 30% 30%,
      #fff 0%,
      rgba(255, 255, 255, 0) 60%
    );
    box-shadow: 0 0 8px rgba(255, 235, 120, 0.9);
    opacity: 0;
    pointer-events: none;
    animation: glitter 2.5s infinite linear;
  }

  .nav-link:visited {
    color: #00ffff;
  }

  .nav-link:hover,
  .nav-link:focus {
    background-color: rgba(0, 255, 255, 0.15);
    color: #ff00ff;
    text-shadow:
      0 0 10px rgba(255, 0, 255, 0.8),
      0 0 20px rgba(0, 255, 255, 0.5);
    border-left: 4px solid #ff00ff;
    padding-left: 16px;
  }

  /* For the click-now link, hover intensifies gold and sparkle */
  .click-now .nav-link:hover,
  .click-now .nav-link:focus {
    color: #fff7d1;
    background: linear-gradient(
      90deg,
      rgba(255, 215, 0, 0.15),
      rgba(255, 223, 93, 0.12)
    );
    text-shadow:
      0 0 12px rgba(255, 215, 0, 1),
      0 0 30px rgba(255, 184, 28, 0.7);
    border-left: 6px solid rgba(255, 215, 0, 0.9);
    padding-left: 14px;
  }

  .nav-link::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 0;
    height: 100%;
    background: rgba(0, 255, 255, 0.1);
    transition: width 0.3s ease;
  }

  .nav-link:hover::before {
    width: 100%;
  }

  /* shimmer animation */
  @keyframes shimmer {
    0% {
      transform: translateX(-120%) rotate(25deg);
      opacity: 0.4;
    }
    50% {
      transform: translateX(10%) rotate(25deg);
      opacity: 0.9;
    }
    100% {
      transform: translateX(120%) rotate(25deg);
      opacity: 0.4;
    }
  }

  /* small glitter pops */
  @keyframes glitter {
    0%,
    80% {
      opacity: 0;
    }
    85% {
      opacity: 1;
      transform: scale(1) translateY(-6px);
    }
    100% {
      opacity: 0;
      transform: scale(0.6) translateY(-12px);
    }
  }

  /* Scanline effect */
  .nav-terminal::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.1),
      rgba(0, 0, 0, 0.1) 1px,
      transparent 1px,
      transparent 2px
    );
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .terminal-title {
      font-size: 0.8rem;
      letter-spacing: 2px;
    }

    .nav-link {
      font-size: 0.9rem;
      padding: 12px 16px;
    }
  }
</style>
