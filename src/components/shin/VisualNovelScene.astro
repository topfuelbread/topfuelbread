---
import AsciiContainer from "../../content/ascii/AsciiContainer.astro";
import type { Scene } from "../../lib/shin/types";
import FlagMeter from "./FlagMeter.astro";

interface Props {
  scene: Scene;
  showFlags?: boolean;
}

const { scene, showFlags = true } = Astro.props;
---

<div class="vn-stage">
  {showFlags && <FlagMeter />}
  <AsciiContainer name={scene.asciiArt} />
  <div class="vn-dialogue">
    <div class="vn-speaker">{scene.speaker}</div>
    <p class="vn-text">{scene.dialogue}</p>
  </div>
  <div class="vn-choices">
    {
      scene.choices.map((choice) => (
        <a
          class="vn-choice"
          href={choice.href}
          {...(choice.flags
            ? { "data-flags": JSON.stringify(choice.flags) }
            : {})}
        >
          {choice.label}
        </a>
      ))
    }
  </div>
</div>

<script>
  import { applyFlags } from "../../lib/shin/flags";
  import type { FlagState } from "../../lib/shin/types";

  function bindChoiceFlags() {
    document.querySelectorAll(".vn-choice[data-flags]").forEach((el) => {
      if (el instanceof HTMLAnchorElement && el.dataset.bound) return;
      if (!(el instanceof HTMLAnchorElement)) return;

      el.dataset.bound = "true";
      el.addEventListener("click", () => {
        const raw = el.getAttribute("data-flags");
        if (!raw) return;
        applyFlags(JSON.parse(raw) as FlagState);
      });
    });
  }

  bindChoiceFlags();
  document.addEventListener("astro:page-load", bindChoiceFlags);
</script>
