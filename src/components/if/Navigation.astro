<nav class="retro-nav">
  <div class="nav-terminal">
    <div class="terminal-header">
      <span class="terminal-title">[ NAVIGATION ]</span>
    </div>
    <ul class="nav-list">
      <li><a href="/about/" class="nav-link">▶ About</a></li>
      <li>
        <a href="/if/ascii-art-gallery/" class="nav-link"
          >▶ ASCII ART GALLERY</a>
      </li>
      <li><a href="/if/shin-ai/" class="nav-link">▶ shin-ai v0.0.1</a></li>
    </ul>
  </div>
</nav>

<style>
  @import url("https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&display=swap");

  .retro-nav {
    margin-bottom: 30px;
    font-family: "JetBrains Mono", monospace;
  }

  .nav-terminal {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a0a2e 100%);
    border: 3px solid #00ffff;
    border-radius: 0;
    box-shadow:
      0 0 20px rgba(0, 255, 255, 0.5),
      inset 0 0 20px rgba(0, 255, 255, 0.1);
    overflow: hidden;
  }

  .terminal-header {
    background-color: rgba(0, 255, 255, 0.1);
    border-bottom: 2px solid #00ffff;
    padding: 12px 16px;
    text-align: center;
  }

  .terminal-title {
    color: #00ffff;
    font-weight: 700;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    text-shadow: 0 0 10px rgba(0, 255, 255, 0.8);
  }

  .nav-list {
    list-style: none;
    margin: 0;
    padding: 16px 0;
  }

  .nav-list li {
    border-bottom: 1px solid rgba(0, 255, 255, 0.2);
  }

  .nav-list li:last-child {
    border-bottom: none;
  }

  .nav-link {
    display: block;
    padding: 16px 20px;
    text-decoration: none;
    color: #00ffff;
    font-size: 1rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    transition: all 0.3s ease;
    position: relative;

    text-shadow:
      0 0 5px rgba(0, 255, 255, 0.8),
      0 0 10px rgba(255, 0, 255, 0.3);
  }

  .nav-link:visited {
    color: #00ffff;
  }

  .nav-link:hover,
  .nav-link:focus {
    background-color: rgba(0, 255, 255, 0.15);
    color: #ff00ff;
    text-shadow:
      0 0 10px rgba(255, 0, 255, 0.8),
      0 0 20px rgba(0, 255, 255, 0.5);
    border-left: 4px solid #ff00ff;
    padding-left: 16px;
  }

  .nav-link::before {
    content: "";
    position: absolute;
    left: 0;
    top: 0;
    width: 0;
    height: 100%;
    background: rgba(0, 255, 255, 0.1);
    transition: width 0.3s ease;
  }

  .nav-link:hover::before {
    width: 100%;
  }

  /* Scanline effect */
  .nav-terminal::after {
    content: "";
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.1),
      rgba(0, 0, 0, 0.1) 1px,
      transparent 1px,
      transparent 2px
    );
    pointer-events: none;
  }

  @media (max-width: 640px) {
    .terminal-title {
      font-size: 0.8rem;
      letter-spacing: 2px;
    }

    .nav-link {
      font-size: 0.9rem;
      padding: 12px 16px;
    }
  }
</style>
