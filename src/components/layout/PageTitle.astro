---
const { pageTitle } = Astro.props;
---

<div class="page-title flex-center">
  <img
    src="https://blob.gifcities.org/gifcities/3C3YRRQ6C7EGPWXNVMER4OMEJWJRDTSN.gif"
  />
  <div>topfuelbread:: {pageTitle}</div>
  <img
    src="https://blob.gifcities.org/gifcities/3C3YRRQ6C7EGPWXNVMER4OMEJWJRDTSN.gif"
  />
</div>

<style>
  .page-title {
    background-color: rgb(240, 192, 255);
    border: solid rgb(255, 152, 238);
    font-size: 22px;
    color: rgb(253, 243, 255);
    text-shadow: 0px 0px 15px rgba(45, 195, 255, 0.651);
    font-weight: 600;
    padding: 5px 0px;
  }
</style>
