---
import { render } from "astro:content";
import { getBlogPost } from "../../lib/blog";
import { pubDateToSlug } from "../../lib/twt";

interface Props {
  /** Content collection id, e.g. `blog/2026/07/03` */
  id: string;
}

const { id } = Astro.props;
const post = await getBlogPost(id);

if (!post) {
  return null;
}

const { Content } = await render(post);
const bodyTrimmed = (post.body ?? "").trim();
const isEmpty = bodyTrimmed.length === 0;
const SUMMARY_LIMIT = 300;
const likelyTruncated = !isEmpty && bodyTrimmed.length > SUMMARY_LIMIT;
const daySlug = pubDateToSlug(post.data.pubDate);
---

<div class="blog-post-summary-container">
  <article class="blog-post-summary">
    <div class="pub-date">{post.data.pubDate}</div>
    <h3>
      <a href={`/${post.id}/`}>{post.data.title}</a>
    </h3>
    {
      isEmpty ? (
        <a class="read-more" href={`/twt/${daySlug}/`}>
          View today's twts →
        </a>
      ) : (
        <>
          <div
            class:list={["post-content", { "is-truncated": likelyTruncated }]}
            data-preview-max-height="300"
          >
            <Content />
          </div>
          {
            likelyTruncated && (
              <a class="read-more" href={`/${post.id}/`}>
                Read more
              </a>
            )
          }
        </>
      )
    }
  </article>
</div>

<style>
  .blog-post-summary-container {
    border: dotted 2px #79ffcc;
    background-color: #cbfff631;
    padding: 10px;
    margin-bottom: 20px;
    text-align: left;
  }

  .blog-post-summary .pub-date {
    font-size: 12px;
    color: rgb(255, 255, 255);
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.651);
  }

  .blog-post-summary h3 a {
    color: #ffe0f3;
    text-decoration: none;
    text-shadow: 1px 1px 2px rgba(255, 0, 155, 0.651);
  }

  .blog-post-summary .post-content {
    line-height: 1.3;
    color: rgb(250, 223, 255);
    font-family: monospace;
    text-align: left;
    max-height: 300px;
    overflow: hidden;
    position: relative;
  }

  .blog-post-summary .post-content.is-truncated::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3rem;
    background: linear-gradient(transparent, rgba(203, 255, 246, 0.85));
    pointer-events: none;
  }

  .read-more {
    display: inline-block;
    margin-top: 12px;
    padding: 6px 14px;
    border: dotted 2px #79ffcc;
    border-radius: 6px;
    background-color: #63ffc33a;
    color: #ffe0f3;
    font-family: monospace;
    font-size: 0.9rem;
    text-decoration: none;
    text-shadow: 1px 1px 2px rgba(255, 0, 155, 0.651);
  }

  .read-more:hover {
    background-color: #79ffcc55;
    color: #fff;
  }
</style>
