---
import { render, type CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content } = await render(post);

const likelyTruncated = post.body.trim().length > 400;
---

<div class="import-latest-blog-post-container">
  <article class="latest-blog-post">
    <div class="pub-date">
      {post.data.pubDate.toISOString().split("T")[0]}
    </div>
    <h3>
      <a href={`/blog/${post.id}/`}>{post.data.title}</a>
    </h3>
    <div
      class:list={["post-content", { "is-truncated": likelyTruncated }]}
      data-preview-max-height="300"
    >
      <Content />
    </div>
    {
      likelyTruncated && (
        <a class="read-more" href={`/blog/${post.id}/`}>
          Read more
        </a>
      )
    }
  </article>
</div>

<style>
  .import-latest-blog-post-container {
    border: dotted 2px #79ffcc;
    background-color: #cbfff631;
    padding: 10px;
    margin-bottom: 20px;
    text-align: center;
  }

  .latest-blog-post .pub-date {
    font-size: 12px;
    color: rgb(255, 255, 255);
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.651);
  }

  .latest-blog-post h3 a {
    color: #ffe0f3;
    text-decoration: none;
    text-shadow: 1px 1px 2px rgba(255, 0, 155, 0.651);
  }

  .latest-blog-post .post-content {
    line-height: 1.3;
    color: rgb(250, 223, 255);
    font-family: monospace;
    text-align: left;
    max-height: 300px;
    overflow: hidden;
    position: relative;
  }

  .latest-blog-post .post-content.is-truncated::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 3rem;
    background: linear-gradient(transparent, rgba(203, 255, 246, 0.85));
    pointer-events: none;
  }

  .read-more {
    display: inline-block;
    margin-top: 12px;
    padding: 6px 14px;
    border: dotted 2px #79ffcc;
    border-radius: 6px;
    background-color: #63ffc33a;
    color: #ffe0f3;
    font-family: monospace;
    font-size: 0.9rem;
    text-decoration: none;
    text-shadow: 1px 1px 2px rgba(255, 0, 155, 0.651);
  }

  .read-more:hover {
    background-color: #79ffcc55;
    color: #fff;
  }
</style>
