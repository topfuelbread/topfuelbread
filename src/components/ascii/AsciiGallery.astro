---
import AsciiContainer from "../../content/ascii/AsciiContainer.astro";
import type { ArtPiece } from "../../lib/ascii/listArt";

interface Props {
  pieces: ArtPiece[];
}

const { pieces } = Astro.props;
---

<div class="gallery-container">
  <div class="gallery-grid">
    {
      pieces.map((art) => (
        <div class="gallery-item">
          <div class="item-title">{art.title}</div>
          <AsciiContainer name={art.name} />
        </div>
      ))
    }
  </div>
</div>

<style>
  :global(.vn-game-content) {
    justify-content: flex-start;
    align-items: stretch;
  }

  .gallery-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1rem 0;
    width: 100%;
    min-width: 0;
    max-width: 100%;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
    width: 100%;
    min-width: 0;
  }

  .gallery-item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    min-width: 0;
  }

  .item-title {
    font-family: "Georgia", serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-align: center;
    color: #00ff00;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
    padding: 0.5rem 0;
    border-bottom: 2px solid #00ff00;
    margin-bottom: 0.25rem;
  }

  .gallery-item :global(.ascii-panel) {
    width: 100%;
    min-width: 0;
    height: 550px;
    min-height: 550px;
    max-height: 550px;
    flex: none;
    display: flex;
    flex-direction: column;
  }

  .gallery-item :global(.ascii-viewport) {
    flex: 1;
    min-height: 0;
    overflow: auto;
    max-height: 100%;
    -webkit-overflow-scrolling: touch;
  }

  .gallery-item :global(code) {
    font-size: 9px !important;
  }

  .gallery-item :global(.ascii-viewport--svg) {
    display: flex;
    align-items: flex-start;
    justify-content: center;
  }

  .gallery-item :global(.ascii-viewport--svg svg) {
    flex-shrink: 0;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: minmax(0, 1fr);
      gap: 2rem;
    }

    .gallery-item :global(.ascii-panel) {
      height: 420px;
      min-height: 420px;
      max-height: 420px;
    }

    .gallery-item :global(code) {
      font-size: 8px !important;
    }
  }
</style>
