---
import { listAsciiCollections } from "../../lib/ascii/listArt";

interface Props {
  active?: string;
}

const { active } = Astro.props;
const collections = listAsciiCollections();
---

<nav class="gallery-nav" aria-label="ASCII art collections">
  <div class="gallery-nav-terminal">
    <div class="gallery-nav-header">
      <span class="gallery-nav-title">[ COLLECTIONS ]</span>
    </div>
    <ul class="gallery-nav-list">
      <li>
        <a
          href="/if/ascii-art-gallery/"
          class:list={["gallery-nav-link", { active: !active }]}>▶ All</a
        >
      </li>
      {
        collections.map((collection) => (
          <li>
            <a
              href={`/if/ascii-art-gallery/${collection}/`}
              class:list={[
                "gallery-nav-link",
                { active: active === collection },
              ]}
            >
              ▶ {collection}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</nav>

<style>
  .gallery-nav {
    margin-bottom: 1.5rem;
    font-family: "JetBrains Mono", monospace;
  }

  .gallery-nav-terminal {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a0a2e 100%);
    border: 3px solid #00ffff;
    box-shadow:
      0 0 20px rgba(0, 255, 255, 0.5),
      inset 0 0 20px rgba(0, 255, 255, 0.1);
    overflow: hidden;
  }

  .gallery-nav-header {
    background-color: rgba(0, 255, 255, 0.1);
    border-bottom: 2px solid #00ffff;
    padding: 10px 16px;
    text-align: center;
  }

  .gallery-nav-title {
    color: #00ffff;
    font-weight: 700;
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 3px;
    text-shadow: 0 0 10px rgba(0, 255, 255, 0.8);
  }

  .gallery-nav-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0;
  }

  .gallery-nav-list li {
    flex: 1 1 auto;
    border-right: 1px solid rgba(0, 255, 255, 0.2);
  }

  .gallery-nav-list li:last-child {
    border-right: none;
  }

  .gallery-nav-link {
    display: block;
    padding: 12px 16px;
    text-decoration: none;
    color: #00ffff;
    font-size: 0.9rem;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-align: center;
    transition: all 0.3s ease;
    text-shadow: 0 0 5px rgba(0, 255, 255, 0.8);
  }

  .gallery-nav-link:hover,
  .gallery-nav-link:focus {
    background-color: rgba(0, 255, 255, 0.15);
    color: #ff00ff;
    text-shadow:
      0 0 10px rgba(255, 0, 255, 0.8),
      0 0 20px rgba(0, 255, 255, 0.5);
  }

  .gallery-nav-link.active {
    background-color: rgba(0, 255, 0, 0.12);
    color: #00ff00;
    text-shadow: 0 0 10px rgba(0, 255, 0, 0.8);
    border-bottom: 3px solid #00ff00;
  }

  @media (max-width: 640px) {
    .gallery-nav-list {
      flex-direction: column;
    }

    .gallery-nav-list li {
      border-right: none;
      border-bottom: 1px solid rgba(0, 255, 255, 0.2);
    }

    .gallery-nav-list li:last-child {
      border-bottom: none;
    }
  }
</style>
