---
import type { FlagId } from "../../lib/vn/types";

interface Props {
  novelId: string;
  flagIds: FlagId[];
}

const { novelId, flagIds } = Astro.props;
---

<div class="vn-flag-meter" data-flag-meter data-novel-id={novelId}>
  {
    flagIds.map((id) => (
      <div class="vn-flag-item" data-flag={id}>
        <span class="vn-flag-label">{id}</span>
        <div class="vn-flag-bar">
          <div class="vn-flag-fill" data-flag-fill />
        </div>
        <span class="vn-flag-value" data-flag-value>0</span>
      </div>
    ))
  }
</div>

<script>
  import { getFlags } from "../../lib/vn/flags";

  function updateFlagMeter() {
    const meter = document.querySelector("[data-flag-meter]");
    if (!meter || !(meter instanceof HTMLElement)) return;

    const novelId = meter.dataset.novelId;
    if (!novelId) return;

    const flags = getFlags(novelId);
    const items = meter.querySelectorAll("[data-flag]");

    for (const item of items) {
      if (!(item instanceof HTMLElement)) continue;

      const id = item.dataset.flag;
      if (!id) continue;

      const value = flags[id] ?? 0;
      const fill = item.querySelector("[data-flag-fill]");
      const valueEl = item.querySelector("[data-flag-value]");

      if (fill instanceof HTMLElement) {
        fill.style.width = `${Math.min(100, Math.max(0, value))}%`;
      }
      if (valueEl) {
        valueEl.textContent = String(value);
      }
    }
  }

  updateFlagMeter();
  document.addEventListener("astro:page-load", updateFlagMeter);
</script>
