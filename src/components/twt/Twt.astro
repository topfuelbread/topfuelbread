---
import { render, type CollectionEntry } from "astro:content";
import AsciiContainer from "../../content/ascii/AsciiContainer.astro";
import { parseTwtId } from "../../lib/twt";

type Props = {
  entry: CollectionEntry<"twt">;
  linkToDay?: boolean;
};

const { entry, linkToDay = true } = Astro.props;
const { Content } = await render(entry);
const { daySlug, sortKey } = parseTwtId(entry.id);
---

<div class="twt">
  <article class="twt-card">
    <header class="twt-header">
      <h3 class="twt-title">
        {
          linkToDay ? (
            <a href={`/twt/${daySlug}/`}>{entry.data.title}</a>
          ) : (
            entry.data.title
          )
        }
      </h3>
      <time class="twt-id" datetime={sortKey}>{sortKey}</time>
    </header>
    <div class="twt-content">
      <Content />
    </div>
    {entry.data.asciiArt && <AsciiContainer name={entry.data.asciiArt} />}
  </article>
</div>

<style>
  .twt {
    border: 1px dotted pink;
    padding: 10px;
    margin-bottom: 16px;
    background-color: rgba(255, 255, 255, 0.3);
    color: black;
    text-align: left;
  }

  .twt-header {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .twt-title {
    margin: 0;
    color: white;
    text-shadow: 5px 5px 5px pink;
    font-size: 18px;
    text-decoration: underline;
    text-decoration-color: pink;
    text-decoration-thickness: 2px;
    text-decoration-style: dotted;
  }

  .twt-title a {
    color: inherit;
    text-decoration: none;
  }

  .twt-title a:hover {
    text-decoration: underline;
  }

  .twt-id {
    font-size: 12px;
    color: rgb(255, 255, 255);
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.651);
    font-family: monospace;
  }

  .twt-content {
    text-align: left;
    color: black;
    text-shadow: 5px 5px 5px rgb(0, 255, 255);
    border-bottom: 1px solid purple;
  }

  .twt-content :global(p) {
    margin: 0.5rem 0;
  }
</style>
