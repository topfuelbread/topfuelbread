---
import { render, type CollectionEntry } from "astro:content";
import AsciiContainer from "../../content/ascii/AsciiContainer.astro";
import { parseTwtId } from "../../lib/twt";

type Props = {
  entry: CollectionEntry<"twt">;
  linkToDay?: boolean;
  featured?: boolean;
};

const { entry, linkToDay = true, featured = false } = Astro.props;
const { Content } = await render(entry);
const { daySlug, time } = parseTwtId(entry.id);
---

<div class:list={["twt", { "twt--featured": featured }]}>
  <article class="twt-card">
    <header class="twt-header">
      <h3 class="twt-title">
        {
          linkToDay ? (
            <a href={`/twt/${daySlug}/`}>{time}</a>
          ) : (
            time
          )
        }
      </h3>
    </header>
    <div class="twt-content">
      <Content />
    </div>
    {entry.data.asciiArt && <AsciiContainer name={entry.data.asciiArt} />}
  </article>
</div>

<style>
  .twt {
    border: 1px dotted pink;
    padding: 10px;
    margin-bottom: 16px;
    background-color: rgba(255, 255, 255, 0.3);
    color: black;
    text-align: left;
  }

  .twt-header {
    margin-bottom: 0.5rem;
  }

  .twt-title {
    margin: 0;
    color: white;
    text-shadow: 5px 5px 5px pink;
    font-size: 18px;
    text-decoration: underline;
    text-decoration-color: pink;
    text-decoration-thickness: 2px;
    text-decoration-style: dotted;
  }

  .twt-title a {
    color: inherit;
    text-decoration: none;
  }

  .twt-title a:hover {
    text-decoration: underline;
  }

  .twt-content {
    text-align: left;
    color: black;
    text-shadow: 5px 5px 5px rgb(0, 255, 255);
  }

  .twt-content :global(p) {
    margin: 0.5rem 0;
  }

  .twt--featured {
    border: 2px dotted #ffd700;
    background: linear-gradient(
      135deg,
      rgba(255, 215, 0, 0.35),
      rgba(255, 180, 0, 0.2)
    );
    box-shadow:
      0 0 16px rgba(255, 215, 0, 0.45),
      inset 0 0 24px rgba(255, 215, 0, 0.12);
  }

  .twt--featured .twt-title {
    color: #ffd700;
    text-shadow:
      -1px -1px 0 #000,
      1px -1px 0 #fffc52,
      -1px 1px 0 #dbb800,
      1px 1px 0 #ff9500,
      0 0 8px rgba(255, 215, 0, 0.8);
    text-decoration-color: #ffb300;
  }

  .twt--featured .twt-content {
    text-shadow: 2px 2px 4px rgba(255, 200, 0, 0.55);
    border-bottom-color: #ffd700;
  }
</style>
