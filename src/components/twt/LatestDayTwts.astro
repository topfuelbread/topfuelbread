---
import Twt from "./Twt.astro";
import TwtsList from "./TwtsList.astro";
import { getTwtDates, getTwtsForDayDisplay } from "../../lib/twt";

type Props = {
  linkToDay?: boolean;
  excludeEntryId?: string;
};

const { linkToDay = false, excludeEntryId } = Astro.props;
const [latestDay] = await getTwtDates();
const latestDayDisplay = latestDay
  ? await getTwtsForDayDisplay(latestDay.date)
  : null;

const mainTwt =
  latestDayDisplay?.mainTwt?.id === excludeEntryId
    ? undefined
    : latestDayDisplay?.mainTwt;
const twts =
  latestDayDisplay?.twts.filter((entry) => entry.id !== excludeEntryId) ?? [];
---

{
  latestDay &&
    latestDayDisplay &&
    (mainTwt || twts.length > 0) && (
      <section class="latest-date-twts">
        <h3>{latestDay.date}</h3>
        {mainTwt && <Twt entry={mainTwt} {linkToDay} featured />}
        <TwtsList entries={twts} {linkToDay} />
      </section>
    )
}

<style>
  h3 {
    color: white;
    text-shadow: 2px 2px 2px rgba(0, 0, 0, 0.651);
    text-align: center;
  }
</style>
