---
import BaseLayout from "../layouts/BaseLayout.astro";
import DiaryEntry from "../components/diary/DiaryEntry.astro";
import BlogPostSummary from "../components/blog/BlogPostSummary.astro";
import { getLatestBlogPostId } from "../lib/blog";
import { getDiaryEntries } from "../lib/diary";

const pageTitle = "Welcome!";

const diaryEntries = [...(await getDiaryEntries())].sort((a, b) =>
  b.id.localeCompare(a.id),
);
const [featuredDiaryEntry, ...olderDiaryEntries] = diaryEntries;
const latestPostId = await getLatestBlogPostId();
---

<BaseLayout pageTitle={pageTitle}>
  <header class="home-intro">
    <h2>
      안녕하세요 파란새에게 유령밴을 당한 코가 길어 슬픈 개미핥기의 갠홈에
      어서오세요...
    </h2>
    <a class="if-portal" href="/if/">
      <img
        src="https://blob.gifcities.org/gifcities/V54WUS2GWCSI647WCDLP5SF6DQZ75RZA.gif"
        alt=""
      />
      <p>^^위 웰컴을 클릭하시면 다른 세계로 데려가 준다네요^^</p>
    </a>
  </header>

  <div class="content-wrapper">
    {
      featuredDiaryEntry && (
        <section class="featured-diary">
          <p class="featured-diary__label">New!</p>
          <DiaryEntry entry={featuredDiaryEntry} />
        </section>
      )
    }
    {latestPostId && <BlogPostSummary id={latestPostId} />}
    {olderDiaryEntries.map((entry) => (
      <DiaryEntry entry={entry} />
    ))}
  </div>

  <style>
    .home-intro {
      text-align: center;
      margin-bottom: 15px;
      padding-bottom: 10px;
      color: white;
      border-bottom: 1px solid white;
    }

    .if-portal {
      color: inherit;
      text-decoration: none;
    }

    .featured-diary {
      margin-bottom: 20px;
    }

    .featured-diary__label {
      margin: 0 0 0.5rem;
      text-align: left;
      font-size: 25px;
      font-weight: bold;
      color: gold;
      text-decoration: underline;
      text-shadow:
        -2px -2px 0 #000,
        2px -2px 0 #fffc52,
        -2px 2px 0 #d0ff00,
        2px 2px 0 #fffb0b,
        -3px 0 0 #e5ff00,
        3px 0 0 #fbff00,
        0 -3px 0 #fff020,
        0 3px 0 #8400ff;
    }
  </style>
</BaseLayout>
