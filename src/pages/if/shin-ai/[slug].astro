---
import VisualNovelScene from "../../../components/vn/VisualNovelScene.astro";
import VnLayout from "../../../layouts/VNLayout.astro";
import { shinAi } from "../../../lib/vn/novels/shin-ai/config";
import { getScene, scenes } from "../../../lib/vn/novels/shin-ai/scenes";

export function getStaticPaths() {
  return Object.keys(scenes).map((slug) => ({ params: { slug } }));
}

const { slug } = Astro.params;
const scene = getScene(slug!);
---

<VnLayout pageTitle={scene.title}>
  <VisualNovelScene
    scene={scene}
    novelId={shinAi.id}
    flagIds={shinAi.flagIds}
  />
</VnLayout>
