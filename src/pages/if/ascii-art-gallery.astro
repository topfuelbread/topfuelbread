---
import VnLayout from "../../layouts/VNLayout.astro";
import AsciiContainer from "../../content/ascii/AsciiContainer.astro";

const pageTitle = "ASCII Art Gallery";

// Get all ASCII art files
const artModules = import.meta.glob<string>(
  "../../content/ascii/art/yytd/*.html",
  {
    query: "?raw",
    import: "default",
    eager: true,
  },
);

// Extract art names from paths (remove .html extension and ./art/ prefix)
const artPieces = Object.keys(artModules)
  .map((path) =>
    path.replace("../../content/ascii/art/", "").replace(".html", ""),
  )
  .sort();

// Helper to convert filename to fancy title
const getTitleFromArt = (art: string) => {
  const name = art.split("/").pop() ?? art;
  return name;
  // .split("_")
  // .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
  // .join(" ");
};
---

<VnLayout pageTitle={pageTitle}>
  <div class="gallery-container">
    <div class="gallery-grid">
      {
        artPieces.map((art) => (
          <div class="gallery-item">
            <div class="item-title">{getTitleFromArt(art)}</div>
            <AsciiContainer name={art} />
          </div>
        ))
      }
    </div>
  </div>
</VnLayout>

<style>
  .gallery-container {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    padding: 1rem 0;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    width: 100%;
  }

  .gallery-item {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    height: 100%;
    max-height: 700px;
  }

  .item-title {
    font-family: "Georgia", serif;
    font-size: 1.1rem;
    font-weight: 600;
    text-align: center;
    color: #00ff00;
    text-transform: uppercase;
    letter-spacing: 2px;
    text-shadow: 0 0 10px rgba(0, 255, 0, 0.5);
    padding: 0.5rem 0;
    border-bottom: 2px solid #00ff00;
    margin-bottom: 0.25rem;
  }

  /* Override AsciiContainer to be fixed size */
  .gallery-item :global(.ascii-panel) {
    width: 100%;
    height: 350px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }

  .gallery-item :global(.ascii-viewport) {
    flex: 1;
    overflow: auto;
    max-height: 100%;
  }

  .gallery-item :global(code) {
    font-size: 9px !important;
  }

  @media (max-width: 1200px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
