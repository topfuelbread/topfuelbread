<style>
  body {
    background: black;
    color: white;
    word-wrap: break-word;
  }

  a {
    text-decoration: none;
    color: inherit;
  }

  div {
    font-family: monospace;
    animation: glitch 5s infinite;
  }

  @keyframes glitch {
    0% {
      text-shadow:
        2px 0 red,
        -2px 0 blue;
    }
    20% {
      text-shadow:
        -2px -2px lime,
        2px 2px magenta;
    }
    40% {
      text-shadow:
        2px -2px cyan,
        -2px 2px yellow;
    }
    60% {
      text-shadow: none;
    }
    80% {
      opacity: 0.8;
    }
    100% {
      opacity: 1;
    }
  }
</style>
