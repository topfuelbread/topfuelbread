---
import BaseLayout from "../layouts/BaseLayout.astro";

const pageTitle = "Not Here";
---

<BaseLayout pageTitle={pageTitle}>
    <div class="container">
        <h1>Page Not Here</h1>
        <p>The page you are looking for does not exist or has been moved.</p>
        <a href="/">Return home</a>
    </div>

    <style>
        <style > textarea {
            width: 100%;
            height: 500px;
            font-size: 20px;
        }

        .filler {
            width: -moz-available;
        }

        html {
            background-color: black;
            background-image: none;
        }

        .container {
            max-width: 720px;
            margin: 6rem auto;
            padding: 1rem;
            text-align: center;
        }
        h1 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }
        p {
            color: #666;
        }
    </style>

    --- layout: ../layouts/BaseLayout.astro title: Not Here description: A
    placeholder page for routes that are not available. ---

    <main class="container">
        <h1>Page Not Here</h1>
        <p>The page you are looking for does not exist or has been moved.</p>
        <a href="/">Return home</a>
    </main>

    <style>
        .container {
            max-width: 720px;
            margin: 6rem auto;
            padding: 1rem;
            text-align: center;
        }
        h1 {
            font-size: 2rem;
            margin-bottom: 0.5rem;
        }
        p {
            color: #666;
        }
    </style>
</BaseLayout>
