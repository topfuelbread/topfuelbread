---
import BaseLayout from "../layouts/BaseLayout.astro";
import AsciiContainer from "../content/ascii/AsciiContainer.astro";

const pageTitle = "Shin Tsukimi";
---

<BaseLayout pageTitle={pageTitle}>
  <div class="shin">
    <AsciiContainer name="shin" />
  </div>
</BaseLayout>

<style>
  .shin :global(.ascii-panel) {
    border-color: rgb(4, 1, 46);
    background: rgb(4, 1, 46);
  }

  .shin :global(.ascii-viewport) {
    background: rgb(4, 1, 46);
  }

  .shin :global(.ascii-viewport code) {
    font-size: 8px;
    color: rgb(0, 255, 149);
  }
</style>
