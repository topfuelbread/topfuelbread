---
interface Props {
  /** Path relative to src/content/ascii/art/ — loads {name}.html or {name}.svg and optional {name}.css (e.g. totono/miyuki, yytd/shin) */
  name: string;
}

const { name } = Astro.props;

const artSlug = name.split("/").at(-1) ?? name;

const htmlModules = import.meta.glob<string>("./art/**/*.html", {
  query: "?raw",
  import: "default",
  eager: true,
});

const svgModules = import.meta.glob<string>("./art/**/*.svg", {
  query: "?raw",
  import: "default",
  eager: true,
});

const styleModules = import.meta.glob<string>("./art/**/*.css", {
  query: "?raw",
  import: "default",
  eager: true,
});

const htmlPath = `./art/${name}.html`;
const svgPath = `./art/${name}.svg`;
const stylePath = `./art/${name}.css`;
const asciiHtml = htmlModules[htmlPath];
const asciiSvg = svgModules[svgPath];
const artStyle = styleModules[stylePath];
const isSvg = !asciiHtml && !!asciiSvg;
const artContent = asciiHtml ?? asciiSvg;

if (!artContent) {
  const available = [
    ...Object.keys(htmlModules).map((path) =>
      path.replace("./art/", "").replace(".html", ""),
    ),
    ...Object.keys(svgModules).map((path) =>
      path.replace("./art/", "").replace(".svg", ""),
    ),
  ]
    .filter((path, index, paths) => paths.indexOf(path) === index)
    .join(", ");

  throw new Error(
    `ASCII art "${name}" not found. Add src/content/ascii/art/${name}.html or ${name}.svg` +
      (available ? ` (available: ${available})` : ""),
  );
}
---

<div class="ascii-panel" data-art={artSlug}>
  <div
    class:list={["ascii-viewport", { "ascii-viewport--svg": isSvg }]}
    set:html={artContent}
  />
</div>

{artStyle && <style is:global set:html={artStyle} />}

<style>
  .ascii-panel {
    display: flex;
    flex-direction: column;
    width: 100%;
    border: 2px solid #1a1a1a;
    border-radius: 12px;
    background: #000;
    overflow: hidden;
  }

  .ascii-viewport {
    overflow: auto;
    padding: 12px 14px;
    background: #000;
    text-align: center;
  }

  .ascii-viewport :global(code) {
    display: inline-block;
    width: auto;
    max-width: 100%;
    padding: 0;
    background: transparent;
    white-space: pre;
    font-size: 10px;
    font-variant-ligatures: none;
    font-feature-settings:
      "liga" 0,
      "calt" 0;
    letter-spacing: 0;
    tab-size: 4;
    -moz-tab-size: 4;
    text-align: left;
  }

  .ascii-viewport--svg {
    padding: 0;
  }

  .ascii-viewport--svg :global(svg) {
    display: block;
  }
</style>

<script>
  function centerAsciiViewport(viewport: Element) {
    const overflow = viewport.scrollWidth - viewport.clientWidth;
    if (overflow > 0) {
      viewport.scrollLeft = overflow / 2;
    }
  }

  function centerAsciiViewports() {
    document.querySelectorAll(".ascii-viewport").forEach(centerAsciiViewport);
  }

  centerAsciiViewports();
  document.addEventListener("astro:page-load", centerAsciiViewports);
</script>
