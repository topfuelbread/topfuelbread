---
import RootLayout from "./RootLayout.astro";
import "../styles/vn.css";
const { pageTitle } = Astro.props;
---

<RootLayout pageTitle={pageTitle}>
  <body class="vn-game-body">
    <div class="vn-game-frame">
      <a href="/if/" class="vn-game-back">← back to site</a>
      <main class="vn-game-content" transition:animate="fade">
        <slot />
      </main>
    </div>
  </body>
</RootLayout>

<style>
  :global(html) {
    background: linear-gradient(135deg, #0a0a0a 0%, #1a0a2e 100%);
  }
</style>
