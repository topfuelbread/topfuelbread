---
import { ClientRouter } from "astro:transitions";

import "../styles/global.css";
import "../styles/vn.css";

const { pageTitle } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter />
    <title>topfuelbread:: {pageTitle}</title>
  </head>
  <body class="vn-game-body">
    <div class="vn-game-frame">
      <a href="/" class="vn-game-back">← back to site</a>
      <main class="vn-game-content" transition:animate="fade">
        <slot />
      </main>
    </div>
  </body>
</html>
