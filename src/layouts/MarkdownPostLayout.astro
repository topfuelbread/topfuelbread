---
import BaseLayout from "./BaseLayout.astro";
import { formatBlogPubDate } from "../lib/pubDate";

const { frontmatter } = Astro.props;
---

<BaseLayout pageTitle={frontmatter.title}>
  <div class="content-wrapper">
    <div class="date">
      Published on {
        formatBlogPubDate(frontmatter.pubDate, frontmatter.timezone)
      }
    </div>
    <div class="tags">
      {
        frontmatter.tags.map((tag: string) => (
          <p class="tag">
            <a href={`/tags/${tag}`}>{tag}</a>
          </p>
        ))
      }
      <p class="tag">tags:</p>
    </div>
    <div class="post-container">
      <div class="post-content">
        <slot />
      </div>
    </div>
  </div>

  <!-- <Comments id="{frontmatter.id}" /> -->
</BaseLayout>

<style>
  a {
    text-decoration: none;
    color: black;
    font-weight: 200;
  }

  .content-wrapper {
    background-color: rgba(71, 61, 139, 0.616);
    flex: auto;
    margin: 0;
  }

  .date {
    color: yellow;
    text-align: center;
    font-size: 14px;
    font-weight: 600;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    flex-direction: row-reverse;
  }

  .tag {
    border: dotted 1px #a1a1a1;
    padding: 2px 5px;
    font-size: 13px;
    background: rgb(237, 167, 255);
    color: #0000009b;
  }

  .post-container {
    border: dotted 2px #79ffcc;
    background-color: #cbfff631;
    line-height: 2;
    text-align: center;
    flex: auto;
    font-family: monospace;
  }

  .post-content {
    line-height: 1.3;
    color: rgb(250, 223, 255);
  }
</style>
